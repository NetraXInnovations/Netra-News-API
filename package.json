{
  "name": "netra-news-api",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "Blind-first news backend platform for Netra News Hub",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "migrate": "ts-node src/jobs/migrate.ts",
    "ingest": "ts-node src/jobs/ingest.ts",
    "cleanup": "ts-node src/jobs/cleanup.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@supabase/supabase-js": "^2.43.4",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsdom": "^24.1.0",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
