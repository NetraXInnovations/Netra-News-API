    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.3.0",
    "jsdom": "^24.1.3",
    "mongoose": "^9.7.4",
    "pino": "^9.2.0",
